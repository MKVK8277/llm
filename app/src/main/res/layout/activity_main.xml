<?xml version="1.0" encoding="utf-8"?>
<!--
    FIX #7: Removed hardcoded backgroundTint and elevation from HOME tab in XML.
    All tab state is now purely driven by MainActivity.switchTab() programmatically.
    This prevents XML state conflicting with code state.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/papyrus_surface">

    <HorizontalScrollView
        android:id="@+id/tab_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/tab_bar"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_tab_container"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <!-- All 4 tabs identical in XML — state applied purely in code -->
            <Button android:id="@+id/tab_setup"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SETUP"
                android:textSize="11sp" android:textAllCaps="true"
                android:letterSpacing="0.05" android:textStyle="bold"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:textColor="@color/papyrus_secondary"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <Button android:id="@+id/tab_home"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HOME"
                android:textSize="11sp" android:textAllCaps="true"
                android:letterSpacing="0.05" android:textStyle="bold"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:textColor="@color/papyrus_secondary"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <Button android:id="@+id/tab_reading"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="READING"
                android:textSize="11sp" android:textAllCaps="true"
                android:letterSpacing="0.05" android:textStyle="bold"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:textColor="@color/papyrus_secondary"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <Button android:id="@+id/tab_settings"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SETTINGS"
                android:textSize="11sp" android:textAllCaps="true"
                android:letterSpacing="0.05" android:textStyle="bold"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:textColor="@color/papyrus_secondary"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

        </LinearLayout>
    </HorizontalScrollView>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tab_scroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@color/papyrus_surface"/>

</androidx.constraintlayout.widget.ConstraintLayout>
